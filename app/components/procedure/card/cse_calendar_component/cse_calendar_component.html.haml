.fr-col-6.fr-col-md-4.fr-col-lg-3
  = link_to cse_calendar_admin_procedure_path(@procedure), class: 'fr-tile fr-enlarge-link' do
    .fr-tile__body.flex.column.align-center.justify-between
      - if @procedure.cse_dates.any?
        %p.fr-badge.fr-badge--success Configuré
        %div
          .line-count.fr-my-1w
            %p.fr-tag= @procedure.cse_dates.size
      - else
        %p.fr-badge.fr-badge--info À configurer

      %h3.fr-h6.fr-mt-10v Calendrier CSE
      %p.fr-tile-subtitle Définir ou modifier les dates des prochains CSE
      %p.fr-btn.fr-btn--tertiary= t('views.shared.actions.edit')
