.fr-col-6.fr-col-md-4.fr-col-lg-3
  = link_to auto_sync_admin_procedure_path(@procedure), class: 'fr-tile fr-enlarge-link' do
    .fr-tile__body.flex.column.align-center.justify-between
      - if active?
        %p.fr-badge.fr-badge--success Activé
        %div
          .line-count.fr-my-1w
            %p.fr-tag= frequency_label
      - else
        %p.fr-badge.fr-badge--info Désactivé

      %h3.fr-h6.fr-mt-10v Synchronisation auto.
      %p.fr-tile-subtitle Configurer la périodicité de synchronisation des dossiers
      %p.fr-btn.fr-btn--tertiary= t('views.shared.actions.edit')
