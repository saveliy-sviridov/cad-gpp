%p= t(:hello, scope: [:views, :shared, :greetings])

%p
  = t(".email_body.html",
      count: @group.procedure.groupe_instructeurs.count,
      groupe: @group.label,
      email: @current_instructeur_email,
      procedure: @group.procedure.libelle,
      procedure_url: instructeur_procedure_url(@group.procedure))

%p
  Votre compte a été créé pour l'adresse électronique
  %strong #{@instructeur.email}.

%p
  Pour accéder à #{APPLICATION_NAME}, connectez-vous via ProConnect :
  = link_to pro_connect_url, pro_connect_url

%p
  Nous vous invitons aussi à consulter notre tutoriel à destination des nouveaux instructeurs :
  = link_to(INSTRUCTEUR_TUTORIAL_URL, INSTRUCTEUR_TUTORIAL_URL)


= render partial: "layouts/mailers/signature"
